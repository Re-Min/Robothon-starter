<mujoco model="ball_catch">
  <!--
    Ball Catch - 接球任务专用场景
    特点：
    - 五指灵巧手
    - 发射器基座
    - 扩大的滚动区域
    - 优化滚动的摩擦参数
  -->

  <compiler angle="degree" autolimits="true"/>
  <option timestep="0.01" integrator="RK4" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <quality shadowsize="2048"/>
  </visual>

  <default>
    <geom friction="0.8 0.03 0.003" solimp="0.9 0.95 0.001" solref="0.02 1"/>
    <joint damping="5" armature="0.01"/>
  </default>

  <asset>
    <texture name="grid_tex" type="2d" builtin="checker" rgb1="0.84 0.86 0.88" rgb2="0.68 0.72 0.76" width="256" height="256"/>
    <material name="floor_mat" texture="grid_tex" texrepeat="5 5" rgba="0.84 0.86 0.88 1"/>
    <material name="table_mat" rgba="0.46 0.43 0.38 1"/>
    <material name="palm_mat" rgba="0.13 0.22 0.30 1"/>
    <material name="finger_mat" rgba="0.78 0.84 0.88 1"/>
    <material name="thumb_mat" rgba="0.92 0.72 0.50 1"/>
    <material name="finger_joint_mat" rgba="0.10 0.12 0.14 1"/>
    <material name="pad_mat" rgba="0.03 0.035 0.04 1"/>
    <material name="sphere_mat" rgba="0.10 0.62 0.95 1"/>
    <material name="launcher_mat" rgba="0.25 0.25 0.30 1"/>
    <material name="launcher_ramp_mat" rgba="0.35 0.35 0.40 1"/>
    <material name="trigger_mat" rgba="1.00 0.20 0.20 1"/>
  </asset>

  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="2.0 2.0 0.05" material="floor_mat"/>

    <!-- 灯光 -->
    <light name="key_light" pos="0.0 -1.2 1.8" dir="0.0 0.4 -1" diffuse="0.95 0.95 0.92"/>
    <light name="fill_light" pos="-1.0 1.1 1.5" dir="0.5 -0.4 -1" diffuse="0.35 0.40 0.48"/>

    <!-- 摄像头 -->
    <camera name="front_camera" pos="0.36 -0.84 0.70" xyaxes="0.94 0.34 0 -0.16 0.45 0.88" fovy="36"/>
    <camera name="side_camera" pos="-0.50 -0.60 0.65" xyaxes="0.90 0.40 0.15 -0.12 0.42 0.90" fovy="32"/>
    <camera name="top_camera" pos="0.0 0.0 1.32" xyaxes="1 0 0 0 1 0" fovy="42"/>

    <!-- 桌面 - 扩大尺寸以容纳滚动 -->
    <body name="table" pos="0 0 0.36">
      <geom name="table_top" type="box" size="0.65 0.50 0.035" material="table_mat"/>
      <geom name="table_edge_front" type="box" pos="0 -0.51 0.045" size="0.65 0.012 0.014" rgba="0.16 0.17 0.18 1"/>
      <geom name="table_edge_back" type="box" pos="0 0.51 0.045" size="0.65 0.012 0.014" rgba="0.16 0.17 0.18 1"/>
      <geom name="table_edge_left" type="box" pos="-0.66 0 0.045" size="0.012 0.50 0.014" rgba="0.16 0.17 0.18 1"/>
      <geom name="table_edge_right" type="box" pos="0.66 0 0.045" size="0.012 0.50 0.014" rgba="0.16 0.17 0.18 1"/>
    </body>

    <!-- 球发射器基座 -->
    <body name="ball_launcher" pos="-0.50 -0.05 0.405">
      <geom name="launcher_base" type="box" size="0.10 0.06 0.018" material="launcher_mat"/>
      <geom name="launcher_ramp" type="box" pos="0.08 -0.01 0.010" euler="0 15 0" size="0.08 0.05 0.006" material="launcher_ramp_mat"/>
      <site name="launcher_trigger" pos="0.16 0 0.028" size="0.010" rgba="1.0 0.3 0.3 1"/>
    </body>

    <!-- 滚动球 - 低摩擦配置 -->
    <body name="sphere_object" pos="-0.34 -0.06 0.440">
      <freejoint name="sphere_object_joint"/>
      <geom name="sphere_object_geom" type="sphere" size="0.052" material="sphere_mat" mass="0.060" friction="0.5 0.015 0.001"/>
      <site name="ball_velocity_marker" pos="0.052 0 0" size="0.006" rgba="0.3 1.0 0.3 1"/>
    </body>

    <!-- 接球区域标记 -->
    <body name="catch_zone" pos="-0.15 -0.05 0.395">
      <geom name="catch_zone_geom" type="cylinder" size="0.12 0.002" rgba="0.20 0.60 0.20 0.15" contype="0" conaffinity="0"/>
    </body>

    <!-- 障碍物 - 球会碰撞并改变方向 -->
    <body name="obstacle_1" pos="-0.10 0.08 0.400">
      <geom name="obstacle_geom" type="cylinder" size="0.025 0.050" material="launcher_mat" friction="0.3 0.01 0.001"/>
      <site name="obstacle_marker" pos="0 0 0.055" size="0.008" rgba="1.0 0.8 0.2 1"/>
    </body>

    <!-- 障碍物2 - 更大范围 -->
    <body name="obstacle_2" pos="0.05 -0.15 0.400">
      <geom name="obstacle_2_geom" type="cylinder" size="0.020 0.045" material="launcher_mat" friction="0.3 0.01 0.001"/>
      <site name="obstacle_2_marker" pos="0 0 0.050" size="0.006" rgba="0.8 1.0 0.2 1"/>
    </body>

    <!-- 五指灵巧手 - 完整结构 -->
    <body name="palm_body" pos="0 0 0.620">
      <!-- 手部滑动关节 -->
      <joint name="hand_x" type="slide" axis="1 0 0" range="-0.40 0.40" damping="8"/>
      <joint name="hand_y" type="slide" axis="0 1 0" range="-0.22 0.34" damping="8"/>
      <joint name="hand_z" type="slide" axis="0 0 1" range="-0.13 0.06" damping="8"/>
      <!-- 手腕旋转关节 -->
      <joint name="wrist_yaw" type="hinge" axis="0 0 1" range="-35 35" damping="5"/>
      <joint name="wrist_pitch" type="hinge" axis="1 0 0" range="-25 25" damping="5"/>
      <joint name="wrist_roll" type="hinge" axis="0 1 0" range="-25 25" damping="5"/>

      <!-- 手掌结构 -->
      <geom name="wrist_mount_geom" type="cylinder" pos="0 -0.060 0.010" euler="90 0 0" size="0.042 0.045" material="finger_joint_mat" contype="0" conaffinity="0"/>
      <geom name="palm_geom" type="box" pos="0 0 0" size="0.085 0.058 0.022" material="palm_mat" contype="0" conaffinity="0"/>
      <geom name="index_metacarpal_rail" type="capsule" fromto="-0.050 -0.028 0.025 -0.045 0.055 0.024" size="0.004" material="finger_mat" contype="0" conaffinity="0"/>
      <geom name="middle_metacarpal_rail" type="capsule" fromto="-0.018 -0.032 0.026 -0.015 0.060 0.025" size="0.0045" material="finger_mat" contype="0" conaffinity="0"/>
      <geom name="ring_metacarpal_rail" type="capsule" fromto="0.018 -0.030 0.025 0.018 0.058 0.024" size="0.004" material="finger_mat" contype="0" conaffinity="0"/>
      <geom name="little_metacarpal_rail" type="capsule" fromto="0.050 -0.024 0.023 0.050 0.052 0.022" size="0.0038" material="finger_mat" contype="0" conaffinity="0"/>
      <site name="palm_center_site" pos="0 0.045 -0.020" size="0.008" rgba="1 0.9 0.2 1"/>

      <!-- 拇指 - 对掌结构 -->
      <body name="thumb_metacarpal" pos="-0.075 0.018 -0.004" euler="0 0 -48">
        <joint name="thumb_cmc_opposition" type="hinge" axis="-1 0 0" range="0 85" damping="4"/>
        <joint name="thumb_cmc_abduction" type="hinge" axis="0 0 1" range="-10 45" damping="4"/>
        <geom name="thumb_cmc_joint_geom" type="sphere" size="0.016" material="thumb_mat" contype="0" conaffinity="0"/>
        <geom name="thumb_proximal_geom" type="capsule" fromto="0 0 0 0 0.045 0" size="0.014" material="thumb_mat" contype="0" conaffinity="0"/>
        <body name="thumb_proximal" pos="0 0.045 0">
          <joint name="thumb_mcp_flexion" type="hinge" axis="-1 0 0" range="0 85" damping="4"/>
          <geom name="thumb_mcp_joint_geom" type="sphere" size="0.014" material="thumb_mat" contype="0" conaffinity="0"/>
          <geom name="thumb_middle_geom" type="capsule" fromto="0 0 0 0 0.039 0" size="0.013" material="thumb_mat" contype="0" conaffinity="0"/>
          <body name="thumb_distal" pos="0 0.039 0">
            <joint name="thumb_ip_flexion" type="hinge" axis="-1 0 0" range="0 80" damping="4"/>
            <geom name="thumb_ip_joint_geom" type="sphere" size="0.012" material="thumb_mat" contype="0" conaffinity="0"/>
            <geom name="thumb_distal_geom" type="capsule" fromto="0 0 0 0 0.028 0" size="0.012" material="thumb_mat" contype="0" conaffinity="0"/>
            <geom name="thumb_tip_pad" type="sphere" pos="0 0.032 -0.004" size="0.019" material="thumb_mat" contype="1" conaffinity="1"/>
            <site name="thumb_tip_site" pos="0 0.034 -0.004" size="0.006" rgba="1 1 1 1"/>
          </body>
        </body>
      </body>

      <!-- 食指 -->
      <body name="index_metacarpal" pos="-0.045 0.058 0.000">
        <joint name="index_mcp_abduction" type="hinge" axis="0 0 1" range="-16 16" damping="4"/>
        <joint name="index_mcp_flexion" type="hinge" axis="-1 0 0" range="0 95" damping="4"/>
        <geom name="index_mcp_joint_geom" type="sphere" size="0.013" material="finger_joint_mat" contype="0" conaffinity="0"/>
        <geom name="index_proximal_geom" type="capsule" fromto="0 0 0 0 0.065 0" size="0.0115" material="finger_mat" contype="0" conaffinity="0"/>
        <body name="index_middle" pos="0 0.065 0">
          <joint name="index_pip_flexion" type="hinge" axis="-1 0 0" range="0 100" damping="4"/>
          <geom name="index_pip_joint_geom" type="sphere" size="0.011" material="finger_joint_mat" contype="0" conaffinity="0"/>
          <geom name="index_middle_geom" type="capsule" fromto="0 0 0 0 0.046 0" size="0.0105" material="finger_mat" contype="0" conaffinity="0"/>
          <body name="index_distal" pos="0 0.046 0">
            <joint name="index_dip_flexion" type="hinge" axis="-1 0 0" range="0 85" damping="4"/>
            <geom name="index_dip_joint_geom" type="sphere" size="0.0095" material="finger_joint_mat" contype="0" conaffinity="0"/>
            <geom name="index_distal_geom" type="capsule" fromto="0 0 0 0 0.033 0" size="0.0095" material="finger_mat" contype="0" conaffinity="0"/>
            <geom name="index_tip_pad" type="sphere" pos="0 0.037 -0.004" size="0.017" material="pad_mat" contype="1" conaffinity="1"/>
            <site name="index_tip_site" pos="0 0.039 -0.004" size="0.006" rgba="1 1 1 1"/>
          </body>
        </body>
      </body>

      <!-- 中指 -->
      <body name="middle_metacarpal" pos="-0.015 0.062 0.000">
        <joint name="middle_mcp_abduction" type="hinge" axis="0 0 1" range="-12 12" damping="4"/>
        <joint name="middle_mcp_flexion" type="hinge" axis="-1 0 0" range="0 100" damping="4"/>
        <geom name="middle_mcp_joint_geom" type="sphere" size="0.0135" material="finger_joint_mat" contype="0" conaffinity="0"/>
        <geom name="middle_proximal_geom" type="capsule" fromto="0 0 0 0 0.072 0" size="0.012" material="finger_mat" contype="0" conaffinity="0"/>
        <body name="middle_middle" pos="0 0.072 0">
          <joint name="middle_pip_flexion" type="hinge" axis="-1 0 0" range="0 105" damping="4"/>
          <geom name="middle_pip_joint_geom" type="sphere" size="0.0115" material="finger_joint_mat" contype="0" conaffinity="0"/>
          <geom name="middle_middle_geom" type="capsule" fromto="0 0 0 0 0.051 0" size="0.011" material="finger_mat" contype="0" conaffinity="0"/>
          <body name="middle_distal" pos="0 0.051 0">
            <joint name="middle_dip_flexion" type="hinge" axis="-1 0 0" range="0 90" damping="4"/>
            <geom name="middle_dip_joint_geom" type="sphere" size="0.010" material="finger_joint_mat" contype="0" conaffinity="0"/>
            <geom name="middle_distal_geom" type="capsule" fromto="0 0 0 0 0.037 0" size="0.010" material="finger_mat" contype="0" conaffinity="0"/>
            <geom name="middle_tip_pad" type="sphere" pos="0 0.041 -0.004" size="0.0175" material="pad_mat" contype="1" conaffinity="1"/>
            <site name="middle_tip_site" pos="0 0.043 -0.004" size="0.006" rgba="1 1 1 1"/>
          </body>
        </body>
      </body>

      <!-- 无名指 -->
      <body name="ring_metacarpal" pos="0.018 0.060 0.000">
        <joint name="ring_mcp_abduction" type="hinge" axis="0 0 1" range="-12 14" damping="4"/>
        <joint name="ring_mcp_flexion" type="hinge" axis="-1 0 0" range="0 98" damping="4"/>
        <geom name="ring_mcp_joint_geom" type="sphere" size="0.013" material="finger_joint_mat" contype="0" conaffinity="0"/>
        <geom name="ring_proximal_geom" type="capsule" fromto="0 0 0 0 0.067 0" size="0.0115" material="finger_mat" contype="0" conaffinity="0"/>
        <body name="ring_middle" pos="0 0.067 0">
          <joint name="ring_pip_flexion" type="hinge" axis="-1 0 0" range="0 102" damping="4"/>
          <geom name="ring_pip_joint_geom" type="sphere" size="0.011" material="finger_joint_mat" contype="0" conaffinity="0"/>
          <geom name="ring_middle_geom" type="capsule" fromto="0 0 0 0 0.048 0" size="0.0105" material="finger_mat" contype="0" conaffinity="0"/>
          <body name="ring_distal" pos="0 0.048 0">
            <joint name="ring_dip_flexion" type="hinge" axis="-1 0 0" range="0 88" damping="4"/>
            <geom name="ring_dip_joint_geom" type="sphere" size="0.0095" material="finger_joint_mat" contype="0" conaffinity="0"/>
            <geom name="ring_distal_geom" type="capsule" fromto="0 0 0 0 0.034 0" size="0.0095" material="finger_mat" contype="0" conaffinity="0"/>
            <geom name="ring_tip_pad" type="sphere" pos="0 0.038 -0.004" size="0.017" material="pad_mat" contype="1" conaffinity="1"/>
            <site name="ring_tip_site" pos="0 0.040 -0.004" size="0.006" rgba="1 1 1 1"/>
          </body>
        </body>
      </body>

      <!-- 小指 -->
      <body name="little_metacarpal" pos="0.050 0.054 0.000" euler="0 0 6">
        <joint name="little_mcp_abduction" type="hinge" axis="0 0 1" range="-14 18" damping="4"/>
        <joint name="little_mcp_flexion" type="hinge" axis="-1 0 0" range="0 96" damping="4"/>
        <geom name="little_mcp_joint_geom" type="sphere" size="0.012" material="finger_joint_mat" contype="0" conaffinity="0"/>
        <geom name="little_proximal_geom" type="capsule" fromto="0 0 0 0 0.054 0" size="0.0105" material="finger_mat" contype="0" conaffinity="0"/>
        <body name="little_middle" pos="0 0.054 0">
          <joint name="little_pip_flexion" type="hinge" axis="-1 0 0" range="0 100" damping="4"/>
          <geom name="little_pip_joint_geom" type="sphere" size="0.010" material="finger_joint_mat" contype="0" conaffinity="0"/>
          <geom name="little_middle_geom" type="capsule" fromto="0 0 0 0 0.038 0" size="0.0095" material="finger_mat" contype="0" conaffinity="0"/>
          <body name="little_distal" pos="0 0.038 0">
            <joint name="little_dip_flexion" type="hinge" axis="-1 0 0" range="0 85" damping="4"/>
            <geom name="little_dip_joint_geom" type="sphere" size="0.0085" material="finger_joint_mat" contype="0" conaffinity="0"/>
            <geom name="little_distal_geom" type="capsule" fromto="0 0 0 0 0.028 0" size="0.0085" material="finger_mat" contype="0" conaffinity="0"/>
            <geom name="little_tip_pad" type="sphere" pos="0 0.032 -0.004" size="0.016" material="pad_mat" contype="1" conaffinity="1"/>
            <site name="little_tip_site" pos="0 0.034 -0.004" size="0.006" rgba="1 1 1 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- 触觉传感器 -->
  <sensor>
    <touch name="touch_thumb_tip" site="thumb_tip_site"/>
    <touch name="touch_index_tip" site="index_tip_site"/>
    <touch name="touch_middle_tip" site="middle_tip_site"/>
    <touch name="touch_ring_tip" site="ring_tip_site"/>
    <touch name="touch_little_tip" site="little_tip_site"/>
  </sensor>

  <!-- 执行器 -->
  <actuator>
    <!-- 手部滑动执行器 -->
    <position name="act_hand_x" joint="hand_x" kp="160" ctrlrange="-0.40 0.40"/>
    <position name="act_hand_y" joint="hand_y" kp="160" ctrlrange="-0.22 0.34"/>
    <position name="act_hand_z" joint="hand_z" kp="160" ctrlrange="-0.13 0.06"/>
    <!-- 手腕执行器 -->
    <position name="act_wrist_yaw" joint="wrist_yaw" kp="80" ctrlrange="-0.6109 0.6109"/>
    <position name="act_wrist_pitch" joint="wrist_pitch" kp="80" ctrlrange="-0.4363 0.4363"/>
    <position name="act_wrist_roll" joint="wrist_roll" kp="80" ctrlrange="-0.4363 0.4363"/>
    <!-- 拇指执行器 -->
    <position name="act_thumb_cmc_opposition" joint="thumb_cmc_opposition" kp="65" ctrlrange="0 1.4835"/>
    <position name="act_thumb_cmc_abduction" joint="thumb_cmc_abduction" kp="65" ctrlrange="-0.1745 0.7854"/>
    <position name="act_thumb_mcp_flexion" joint="thumb_mcp_flexion" kp="65" ctrlrange="0 1.4835"/>
    <position name="act_thumb_ip_flexion" joint="thumb_ip_flexion" kp="65" ctrlrange="0 1.3963"/>
    <!-- 食指执行器 -->
    <position name="act_index_mcp_abduction" joint="index_mcp_abduction" kp="65" ctrlrange="-0.2793 0.2793"/>
    <position name="act_index_mcp_flexion" joint="index_mcp_flexion" kp="65" ctrlrange="0 1.6581"/>
    <position name="act_index_pip_flexion" joint="index_pip_flexion" kp="65" ctrlrange="0 1.7453"/>
    <position name="act_index_dip_flexion" joint="index_dip_flexion" kp="65" ctrlrange="0 1.4835"/>
    <!-- 中指执行器 -->
    <position name="act_middle_mcp_abduction" joint="middle_mcp_abduction" kp="65" ctrlrange="-0.2094 0.2094"/>
    <position name="act_middle_mcp_flexion" joint="middle_mcp_flexion" kp="65" ctrlrange="0 1.7453"/>
    <position name="act_middle_pip_flexion" joint="middle_pip_flexion" kp="65" ctrlrange="0 1.8326"/>
    <position name="act_middle_dip_flexion" joint="middle_dip_flexion" kp="65" ctrlrange="0 1.5708"/>
    <!-- 无名指执行器 -->
    <position name="act_ring_mcp_abduction" joint="ring_mcp_abduction" kp="65" ctrlrange="-0.2094 0.2443"/>
    <position name="act_ring_mcp_flexion" joint="ring_mcp_flexion" kp="65" ctrlrange="0 1.7104"/>
    <position name="act_ring_pip_flexion" joint="ring_pip_flexion" kp="65" ctrlrange="0 1.7802"/>
    <position name="act_ring_dip_flexion" joint="ring_dip_flexion" kp="65" ctrlrange="0 1.5359"/>
    <!-- 小指执行器 -->
    <position name="act_little_mcp_abduction" joint="little_mcp_abduction" kp="65" ctrlrange="-0.2443 0.3142"/>
    <position name="act_little_mcp_flexion" joint="little_mcp_flexion" kp="65" ctrlrange="0 1.6755"/>
    <position name="act_little_pip_flexion" joint="little_pip_flexion" kp="65" ctrlrange="0 1.7453"/>
    <position name="act_little_dip_flexion" joint="little_dip_flexion" kp="65" ctrlrange="0 1.4835"/>
  </actuator>
</mujoco>
