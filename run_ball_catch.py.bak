"""
run_ball_catch.py - 接球任务主运行脚本

这个脚本实现完整的接球任务：
1. 手部灵活性展示
2. 手部定位到接球位置
3. 球发射
4. 手部主动追踪
5. 抓取闭合
6. 保持稳定
7. 释放

总时长目标：40-60秒
"""
from __future__ import annotations

import argparse
import json
import shutil
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Iterable

import numpy as np

try:
    import imageio.v3 as iio
    import mujoco
except ImportError as exc:
    raise SystemExit(
        "Missing dependency. Install from the repository root with:\n"
        "  python -m pip install -r requirements.txt\n\n"
        f"Original error: {exc}"
    ) from exc

try:
    from PIL import Image, ImageDraw, ImageFont
except ImportError:
    Image = None
    ImageDraw = None
    ImageFont = None

from ball_tracker import (
    BallTracker,
    TRACKING_CONFIGS,
    GRASP_CONFIG,
    FINGER_JOINTS,
    interpolate_pose,
    merge_hand_pose,
    get_joint_limits,
    clamp_to_range,
)

# 项目路径
PROJECT_DIR = Path(__file__).resolve().parent
DEFAULT_SCENE = PROJECT_DIR / "scene_ball_catch.xml"
DEFAULT_OUTPUT_DIR = PROJECT_DIR / "outputs_ball_catch"

# 关节列表
SLIDE_AND_WRIST_JOINTS = (
    "hand_x",
    "hand_y",
    "hand_z",
    "wrist_yaw",
    "wrist_pitch",
    "wrist_roll",
)
JOINT_NAMES = SLIDE_AND_WRIST_JOINTS + FINGER_JOINTS
ACTUATOR_BY_JOINT = {joint_name: f"act_{joint_name}" for joint_name in JOINT_NAMES}

# 触觉传感器
TOUCH_SENSOR_BY_FINGER = {
    "thumb": "touch_thumb_tip",
    "index": "touch_index_tip",
    "middle": "touch_middle_tip",
    "ring": "touch_ring_tip",
    "little": "touch_little_tip",
}
ALL_FINGERS = ("thumb", "index", "middle", "ring", "little")

# 默认难度
DEFAULT_DIFFICULTY = "medium"
DEFAULT_SEED = 42


@dataclass(frozen=True)
class Phase:
    """Phase定义"""
    name: str
    duration_s: float
    hand_x: float
    hand_y: float
    hand_z: float
    wrist_yaw: float = 0.0
    wrist_pitch: float = 0.0
    wrist_roll: float = 0.0
    finger_pose: str = "open"  # open, close, hold
    ball_launch: bool = False
    tracking_enabled: bool = False
    catch_enabled: bool = False
    description: str = ""


def get_default_phases() -> list[Phase]:
    """获取默认的Phase序列"""
    return [
        # Phase 1: 手复位
        Phase(
            name="HAND_RESET",
            duration_s=1.0,
            hand_x=0.0,
            hand_y=-0.13,
            hand_z=0.025,
            wrist_yaw=0.0,
            wrist_pitch=0.0,
            wrist_roll=0.0,
            finger_pose="open",
            description="手部回到初始位置",
        ),
        # Phase 2: 展示灵活性 - 1: 拇指对掌
        Phase(
            name="HAND_DISPLAY_1",
            duration_s=1.5,
            hand_x=0.0,
            hand_y=-0.05,
            hand_z=0.15,
            wrist_yaw=0.0,
            wrist_pitch=0.12,
            wrist_roll=0.0,
            finger_pose="display_1",
            description="展示手部灵活性 - 拇指对掌",
        ),
        # Phase 3: 展示灵活性 - 2: 握拳
        Phase(
            name="HAND_DISPLAY_2",
            duration_s=1.5,
            hand_x=0.0,
            hand_y=-0.05,
            hand_z=0.15,
            wrist_yaw=0.0,
            wrist_pitch=0.12,
            wrist_roll=0.0,
            finger_pose="display_2",
            description="展示手部灵活性 - 握拳",
        ),
        # Phase 3.5: 展示灵活性 - 3: OK手势
        Phase(
            name="HAND_DISPLAY_3",
            duration_s=1.0,
            hand_x=0.0,
            hand_y=-0.05,
            hand_z=0.15,
            wrist_yaw=0.0,
            wrist_pitch=0.12,
            wrist_roll=0.0,
            finger_pose="display_ok",
            description="展示手部灵活性 - OK手势",
        ),
        # Phase 3.6: 展示灵活性 - 4: 捏取手势
        Phase(
            name="HAND_DISPLAY_4",
            duration_s=1.0,
            hand_x=0.0,
            hand_y=-0.05,
            hand_z=0.15,
            wrist_yaw=0.0,
            wrist_pitch=0.12,
            wrist_roll=0.0,
            finger_pose="display_pinch",
            description="展示手部灵活性 - 捏取",
        ),
        # Phase 4: 移动到接球位置 (直接在球的上方，手指尖接近桌面高度)
        Phase(
            name="CATCH_POSITION",
            duration_s=1.5,
            hand_x=-0.34,  # 直接在球的上方
            hand_y=-0.06,
            hand_z=-0.065,  # 降低手的位置，让手指尖更接近桌面
            wrist_yaw=0.0,
            wrist_pitch=0.15,
            wrist_roll=0.0,
            finger_pose="open",
            description="移动到接球准备位置 - 球上方",
        ),
        # Phase 5: 张开手等待发射（手移动到球轨迹上，手在球下方）
        Phase(
            name="BALL_AWAIT",
            duration_s=2.0,  # 更长时间准备
            hand_x=-0.05,  # 球轨迹路径
            hand_y=-0.06,
            hand_z=0.25,  # 手在球下方，手指向上包
            wrist_yaw=0.0,
            wrist_pitch=0.0,  # 手指向上
            wrist_roll=0.0,
            finger_pose="open_wait",
            description="张开手等待球发射",
        ),
        # Phase 6: 发射球 + 追踪
        Phase(
            name="BALL_LAUNCH",
            duration_s=10.0,  # 10秒追踪
            hand_x=-0.05,  # 球轨迹路径
            hand_y=-0.06,
            hand_z=0.25,  # 手在球下方
            wrist_yaw=0.0,
            wrist_pitch=0.15,
            wrist_roll=0.0,
            finger_pose="open_wait",
            ball_launch=True,
            tracking_enabled=True,
            catch_enabled=True,
            description="发射球 + 手部追踪",
        ),
        # Phase 7: 抓取闭合
        Phase(
            name="HAND_CLOSE",
            duration_s=2.0,  # 抓取时间
            hand_x=-0.05,
            hand_y=-0.06,
            hand_z=0.25,  # 手在球下方
            wrist_yaw=0.0,
            wrist_pitch=0.15,
            wrist_roll=0.0,
            finger_pose="close",
            tracking_enabled=True,
            catch_enabled=True,
            description="手指闭合抓取",
        ),
        # Phase 8: 保持稳定
        Phase(
            name="CATCH_HOLD",
            duration_s=3.0,
            hand_x=-0.05,
            hand_y=-0.06,
            hand_z=0.25,
            wrist_yaw=0.0,
            wrist_pitch=0.0,
            wrist_roll=0.0,
            finger_pose="hold",
            catch_enabled=True,
            description="保持稳定",
        ),
        # Phase 9: 释放
        Phase(
            name="CATCH_RELEASE",
            duration_s=1.0,
            hand_x=-0.05,
            hand_y=-0.06,
            hand_z=0.25,
            wrist_yaw=0.0,
            wrist_pitch=0.0,
            wrist_roll=0.0,
            finger_pose="open",
            description="释放球",
        ),
        # Phase 10: 最终报告
        Phase(
            name="FINAL_REPORT",
            duration_s=1.0,
            hand_x=0.0,
            hand_y=-0.13,
            hand_z=0.025,
            wrist_yaw=0.0,
            wrist_pitch=0.0,
            wrist_roll=0.0,
            finger_pose="open",
            description="最终报告",
        ),
    ]


def get_finger_pose(pose_name: str) -> dict[str, float]:
    """获取手指姿态"""
    if pose_name == "open":
        return {
            "thumb_cmc_opposition": 0.18,
            "thumb_cmc_abduction": 0.22,
            "thumb_mcp_flexion": 0.08,
            "thumb_ip_flexion": 0.04,
            "index_mcp_abduction": -0.08,
            "index_mcp_flexion": 0.04,
            "index_pip_flexion": 0.03,
            "index_dip_flexion": 0.02,
            "middle_mcp_abduction": 0.00,
            "middle_mcp_flexion": 0.04,
            "middle_pip_flexion": 0.03,
            "middle_dip_flexion": 0.02,
            "ring_mcp_abduction": 0.05,
            "ring_mcp_flexion": 0.04,
            "ring_pip_flexion": 0.03,
            "ring_dip_flexion": 0.02,
            "little_mcp_abduction": 0.11,
            "little_mcp_flexion": 0.04,
            "little_pip_flexion": 0.03,
            "little_dip_flexion": 0.02,
        }
    elif pose_name == "open_wait":
        return GRASP_CONFIG["open_wait"]
    elif pose_name == "close":
        return GRASP_CONFIG["close_grasp"]
    elif pose_name == "hold":
        return GRASP_CONFIG["hold_stable"]
    elif pose_name == "display_1":
        # 拇指对掌
        return {
            "thumb_cmc_opposition": 0.80,
            "thumb_cmc_abduction": 0.50,
            "thumb_mcp_flexion": 0.50,
            "thumb_ip_flexion": 0.30,
            "index_mcp_abduction": -0.08,
            "index_mcp_flexion": 0.04,
            "index_pip_flexion": 0.03,
            "index_dip_flexion": 0.02,
            "middle_mcp_abduction": 0.00,
            "middle_mcp_flexion": 0.04,
            "middle_pip_flexion": 0.03,
            "middle_dip_flexion": 0.02,
            "ring_mcp_abduction": 0.05,
            "ring_mcp_flexion": 0.04,
            "ring_pip_flexion": 0.03,
            "ring_dip_flexion": 0.02,
            "little_mcp_abduction": 0.11,
            "little_mcp_flexion": 0.04,
            "little_pip_flexion": 0.03,
            "little_dip_flexion": 0.02,
        }
    elif pose_name == "display_2":
        # 握拳
        return {
            "thumb_cmc_opposition": 1.10,
            "thumb_cmc_abduction": 0.40,
            "thumb_mcp_flexion": 0.80,
            "thumb_ip_flexion": 0.60,
            "index_mcp_abduction": -0.10,
            "index_mcp_flexion": 1.00,
            "index_pip_flexion": 0.95,
            "index_dip_flexion": 0.60,
            "middle_mcp_abduction": -0.02,
            "middle_mcp_flexion": 1.00,
            "middle_pip_flexion": 0.95,
            "middle_dip_flexion": 0.60,
            "ring_mcp_abduction": 0.06,
            "ring_mcp_flexion": 1.00,
            "ring_pip_flexion": 0.95,
            "ring_dip_flexion": 0.60,
            "little_mcp_abduction": 0.12,
            "little_mcp_flexion": 1.00,
            "little_pip_flexion": 0.95,
            "little_dip_flexion": 0.60,
        }
    elif pose_name == "display_ok":
        # OK手势 - 拇指食指形成环形
        return {
            "thumb_cmc_opposition": 0.90,
            "thumb_cmc_abduction": 0.50,
            "thumb_mcp_flexion": 0.50,
            "thumb_ip_flexion": 0.80,
            "index_mcp_abduction": -0.08,
            "index_mcp_flexion": 0.90,
            "index_pip_flexion": 0.85,
            "index_dip_flexion": 0.50,
            "middle_mcp_abduction": 0.00,
            "middle_mcp_flexion": 0.04,
            "middle_pip_flexion": 0.03,
            "middle_dip_flexion": 0.02,
            "ring_mcp_abduction": 0.05,
            "ring_mcp_flexion": 0.04,
            "ring_pip_flexion": 0.03,
            "ring_dip_flexion": 0.02,
            "little_mcp_abduction": 0.11,
            "little_mcp_flexion": 0.04,
            "little_pip_flexion": 0.03,
            "little_dip_flexion": 0.02,
        }
    elif pose_name == "display_pinch":
        # 捏取手势 - 拇指食指捏合
        return {
            "thumb_cmc_opposition": 0.75,
            "thumb_cmc_abduction": 0.40,
